{
  "name": "agent-news",
  "version": "1.0.7",
  "description": "AgentNews - AI 智能资讯精选系统 (Electron 桌面版)",
  "author": "strawberry-fdf <strawberry-fdf@users.noreply.github.com>",
  "license": "MIT",
  "main": "electron/main.js",
  "scripts": {
    "----------- 开发 -----------": "",
    "dev": "node scripts/dev.mjs",
    "----------- 代码检查 -----------": "",
    "check": "node scripts/check.mjs",
    "----------- 提交与发布 -----------": "",
    "release": "node scripts/release.mjs --push --allow-dirty",
    "----------- 构建 -----------": "",
    "build": "node scripts/build.mjs",
    "----------- 工具 -----------": "",
    "clean": "rimraf dist build frontend/out frontend/.next",
    "postinstall": "cd frontend && pnpm install",
    "prepare": "husky"
  },
  "dependencies": {
    "electron-updater": "^6.3.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.2",
    "@commitlint/config-conventional": "^20.4.2",
    "@inquirer/prompts": "^8.3.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.0",
    "husky": "^9.1.7",
    "rimraf": "^6.0.0",
    "wait-on": "^8.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron"
    ]
  },
  "build": {
    "extends": "electron-builder.yml"
  }
}
