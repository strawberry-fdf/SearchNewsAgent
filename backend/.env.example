# ==================== MongoDB ====================
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=agent_news

# ==================== LLM Provider ====================
# Supported: "openai", "anthropic"
LLM_PROVIDER=openai

# OpenAI / Qwen (DashScope)
OPENAI_API_KEY=sk-2e7db9ab662743b6880eba316da72fcf
OPENAI_MODEL=qwen-plus
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-20241022

# ==================== Feishu / Lark ====================
# Leave empty if not using notifications
FEISHU_WEBHOOK_URL=
# Optional: signing key for Feishu bot
FEISHU_WEBHOOK_SECRET=

# ==================== Scheduler ====================
# Cron expression for RSS polling interval (minutes)
FETCH_INTERVAL_MINUTES=30

# ==================== LLM Limits ====================
# Max tokens to send to LLM (truncate content beyond this)
MAX_CONTENT_TOKENS=4000

# ==================== Logging ====================
LOG_LEVEL=INFO
