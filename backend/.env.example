# ============================================================
# AgentNews 环境变量配置模板
# ============================================================
# 复制此文件为 .env 并填入实际值:
#   cp .env.example .env
#
# .env 文件已被 .gitignore 忽略，不会提交到仓库。

# ---- SQLite 数据库 ----
# 相对于项目根目录，默认存储在 backend/data/ 下
SQLITE_DB_PATH=backend/data/agent_news.db

# ---- LLM 配置 ----
# 统一使用 OpenAI 兼容模式，支持任意模型
LLM_PROVIDER=openai

# OpenAI / 通义千问 / DeepSeek 等 OpenAI 兼容 API
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# Anthropic（可选）
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-20241022

# ---- 飞书 Webhook 通知（可选）----
FEISHU_WEBHOOK_URL=
FEISHU_WEBHOOK_SECRET=

# ---- 调度 ----
FETCH_INTERVAL_MINUTES=30

# ---- LLM 限制 ----
MAX_CONTENT_TOKENS=4000

# ---- 日志 ----
LOG_LEVEL=INFO
